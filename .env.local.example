# ElectiQ Environment Configuration
# Copy this file to .env.local and fill in your API keys

# ============================================
# Google Cloud API Configuration
# ============================================
# This is required for Speech-to-Text (STT) and Text-to-Speech (TTS) APIs
# Get your API key from: https://console.cloud.google.com/apis/credentials
#
# Required Google Cloud APIs to enable:
# 1. Cloud Text-to-Speech API
# 2. Cloud Speech-to-Text API
#
# To enable APIs:
# 1. Go to https://console.cloud.google.com/apis/library
# 2. Search for "Cloud Text-to-Speech API" and enable it
# 3. Search for "Cloud Speech-to-Text API" and enable it
# 4. Create an API key or use an existing one

GOOGLE_CLOUD_API_KEY=your_google_cloud_api_key_here

# ============================================
# Google AI / Gemini API Configuration
# ============================================
# This is used for the Voti AI assistant (Gemini models)
# Get your API key from: https://aistudio.google.com/apikey

GOOGLE_API_KEY=your_google_ai_api_key_here

# ============================================
# Vertex AI Configuration (Optional)
# ============================================
# If using Vertex AI instead of direct Gemini API
# This takes precedence over GOOGLE_API_KEY for Voti

VERTEX_AI_KEY=your_vertex_ai_api_key_here

# ============================================
# Notes for Indian English Voice Support
# ============================================
# The TTS system uses Google Cloud's Indian English voices:
# - Primary: en-IN-Neural2-A (Female, highest quality)
# - Fallback: en-IN-Wavenet-A (Female, high quality)
#
# The STT system is configured for:
# - Primary language: en-IN (Indian English)
# - Alternative languages: hi-IN (Hindi), en-US (US English)
# This allows for code-switching and Hindi-accented English recognition
#
# ============================================
# Testing Your Configuration
# ============================================
# 1. Start the dev server: npm run dev
# 2. Open the Voti assistant (click the orb in bottom-right)
# 3. Switch to "Voice" mode
# 4. Click the microphone and speak
# 5. Voti should transcribe your speech and respond with Indian English voice